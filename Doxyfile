# Doxyfile for qwrt — generates API reference from include/qwrt/*.h
# Run: doxygen Doxyfile  (output in docs/api/html)

PROJECT_NAME           = qwrt
PROJECT_NUMBER         = 0.1.0
PROJECT_BRIEF          = "Embeddable QuickJS-ng runtime wrapper"
INPUT                  = include/qwrt README.md
RECURSIVE              = YES
OUTPUT_DIRECTORY       = docs/api
EXTRACT_ALL            = YES
EXTRACT_STATIC         = YES
GENERATE_LATEX         = NO
GENERATE_HTML          = YES
HTML_OUTPUT            = html
USE_MATHJAX            = NO
JAVADOC_AUTOBRIEF      = YES
QT_AUTOBRIEF           = YES
EXTRACT_ANON_NSPACES   = YES
HIDE_UNDOC_MEMBERS     = NO
HIDE_UNDOC_CLASSES     = NO
WARN_IF_UNDOCUMENTED   = YES
WARN_IF_DOC_ERROR      = YES
QUIET                  = NO
INPUT_ENCODING         = UTF-8
TAB_SIZE               = 4
EXTENSION_MAPPING      = inl=C h=C
FILE_PATTERNS          = *.h *.md
SKIP_FUNCTION_MACROS   = YES
PREDEFINED             = QWRT_WITH_TLS=1 QWRT_WITH_COMPRESS=1 QWRT_WITH_CRYPTO_EXT=1 QWRT_WITH_TEXTCODEC=1 QWRT_HAS_WASM3=1
