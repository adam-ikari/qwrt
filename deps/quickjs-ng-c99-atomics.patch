+/* qwrt: force GCC/Clang __atomic_* builtins so quickjs-ng compiles under C99
+ * (no <stdatomic.h>/C11 _Atomic keyword). __atomic_* builtins are available
+ * on GCC 4.7+ and Clang, so always use them on those compilers regardless of
+ * version. Patched by deps/quickjs-ng-c99-atomics.patch. */
+#if defined(__GNUC__) || defined(__clang__) || defined(__GNUG__)
+#  define GCC_BUILTIN_ATOMICS
 #endif
 
 #ifdef GCC_BUILTIN_ATOMICS
